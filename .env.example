# Hosted PostgreSQL Database Connection URL (e.g., Neon / Supabase / Railway)
DATABASE_URL="postgresql://username:password@hostname:5432/dbname?sslmode=require"

# Upstash Redis REST Credentials (for distributed locking, rate-limiting, and idempotency)
UPSTASH_REDIS_REST_URL="https://your-database-name.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your_upstash_redis_rest_token"

# Authorization secret to protect the Vercel Cron cleanup endpoint
CRON_SECRET="your_vercel_cron_authorization_secret"
